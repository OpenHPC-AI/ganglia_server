#.env
ROOT_PASSWD=admin@@123                              #Enter the root password to set inside container
GANGLIA_USER =ganglia                            #Enter the ganglia user name to handle the ganglia service
GANGLIA_USER_PASSWD=ganglia@@123                      #Enter the ganglia user name password
PORT=9000                                     #Enter the port number of httpd where ganglia run
GRIDNAME=20pf                                 #GRID NAME inside gmetad.conf
CLUSTERNAME=param_rudra                              #Cluster name inside gmond.conf
HOSTIP=172.10.3.201                                   #Where ganglia container run
